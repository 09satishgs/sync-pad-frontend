# ==============================================================================
# SyncPad Frontend Configuration Example File (Vite)
# ==============================================================================
# Instructions:
# 1. Copy this file and rename it to `.env` in the same directory:
#    cp .env.example .env
# 2. Update the variables below with your actual configurations.
# 3. For Vercel production deployment, set these environment variables in your 
#    Vercel project settings dashboard.
# ==============================================================================

# Backend API HTTPS URL (e.g. your Cloudflare Tunnel public address)
# For local dev: http://localhost:5000
VITE_API_URL=http://localhost:5000

# Backend WebSockets WSS URL (e.g. your Cloudflare Tunnel public address)
# For local dev: http://localhost:5000
VITE_WS_URL=http://localhost:5000
